class Handler(http.server.SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, directory=HELP_DIRECTORY, **kwargs)

def documentServer():
    global PORT
    flag=True
    PORT=PORT_LOWER_LIMIT
    while flag:
        try:
            with socketserver.TCPServer(("", PORT), Handler) as httpd:
                flag=False
                httpd.serve_forever()
        except Exception as e:
            PORT+=1

