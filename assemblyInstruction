    global selected_arduino
    if selected_arduino['shield_type']==0: # Baseシールド
        if (1<pin) and (pin<9):
            return True
        return False
    elif selected_arduino['shield_type']==1: # Nanoシールド
        if (2==pin) or (4==pin) or (6==pin):
            return True
        return False
    return False

