def getActuatorGroupList():
    global actuator_info
    return actuator_info['group']['groupList']

def predefineActuatorGroupNeedsDeviceSelection():
    global actuator_info
    for i in getActuatorGroupList():
        if len(actuator_info['group'][i]['device']) > 1:
            actuator_info['group'][i]['needs_device_selection']=True
        else:
            actuator_info['group'][i]['needs_device_selection']=False

def getActuatorCategoryList():
    global actuator_info
    return actuator_info['category']['key']

def predefineActuatorDeviceConnectionType():
    global actuator_info
    for i in (getActuatorCategoryList()):
        for j in (actuator_info[i]['deviceList']):
            # type 整数 : 0 - spi, 1 - i2c, 2 - シリアル, 3 - groveコネクタ1個, 4 - その他
            if int(actuator_info[i][j]['connecter']['spi'])>0:
                actuator_info[i][j]['connecter']['type']=0
            elif int(actuator_info[i][j]['connecter']['i2c'])>0:
                actuator_info[i][j]['connecter']['type']=1
            elif int(actuator_info[i][j]['connecter']['serial'])>0:
                actuator_info[i][j]['connecter']['type']=2
            elif (int(actuator_info[i][j]['connecter']['digital'])==1) or (int(actuator_info[i][j]['connecter']['digital'])==2):
                actuator_info[i][j]['connecter']['type']=3
            else:
                actuator_info[i][j]['connecter']['type']=4

def checkTFvalue(value):
    if value == "True" or value == "true" or value == True:
        return True
    else:
        return False

def exec_command():
    global source_file_name, configuration, error
    try:
        with open(source_file_name, mode='r', encoding='utf-8') as f:
            configuration = yaml.safe_load(f)
    except Exception as e:
        error = 'yamlファイルのロードに失敗しました．'
        return error
    checkResult = checkConfiguration()
    if '' != checkResult:
        error = checkResult
        return error
    return ''

