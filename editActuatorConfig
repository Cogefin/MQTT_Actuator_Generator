#
# 設定ファイルのロード
#
def loadConfigFile():
    global config_file_name, configuration
    try:
        with open(config_file_name, mode='r', encoding='utf-8') as f:
            configuration = yaml.safe_load(f)
    except Exception as e:
        return 'Exception occurred while loading configuration YAML...'
    loadMenuValue()
    return ''

