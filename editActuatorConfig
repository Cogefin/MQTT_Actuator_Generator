# YAMLの論理値を検査
def checkYamlVal(val):
    if (val==False) or (val == "false") or (val == "False") or (val == "FALSE"):
        return False
    return True

# 入力欄の数字確認 isInteger(x) : asciiの数字であることを確認
def isInteger(x):
    if isinstance(x,int):
        return (True, x)
    if isinstance(x,str) and x.isascii() and x.isdecimal():
        return (True, int(x))
    return (False, -1)

# 入力欄の数字の範囲確認(min,max) isNumRange(x, min,max) : max≧x≧min
def isNumRange(x, min,max):
    (flag,val) = isInteger(x)
    if not flag:
        return (False, val)
    if (val < min) or (val > max):
        return (False, val)
    return (True, val)

# 数字(文字列)が数字の特定の値の範囲に収まっているか否かを判定
def strIsNumRange(x, min, max):
    #print(x)
    #x = ''.join(x.split()) # 空白を削除
    return isNumRange(x, min, max)

# ピン番号確認 isPinNumber(x) : Dxxの形式でxxの値の範囲は0から53
def isPinNumber(str):
    #print(str)
    str = ''.join(str.split()) # 空白を削除
    pattern = r'D(\d+)' # Dで始まり、続いて数字が1つ以上あるパターン
    result = re.match(pattern, str)
    #print(result.group(1))
    if result:
        num_str = result.group(1) # 数字の部分を抽出
        #print(num_str)
        return isNumRange(num_str, 0, 53)
    else:
        return (False, -1)

# 入力欄の数字の範囲確認(minのみ) isNumLarger(x,min) : x≧min
def isNumLarger(x, min):
    #print(x)
    (flag,val) = isInteger(x)
    if not flag:
        return (False, val)
    if val < min:
        return (False, val)
    return (True, val)


