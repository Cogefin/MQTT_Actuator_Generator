def init():
    global defaults_file, configuration, error, HELP_FILES, HELP_DIRECTORY
    # check help files.
    pwd=os.getcwd()
    pwd = pwd.replace('\\', '/')
    pwd = pwd.replace(' ', '\\ ')
    pwd = pwd + "/"
    for file in HELP_FILES:
        target_path = HELP_DIRECTORY + file
        if not (os.path.isfile(pwd+target_path)):
            error += "本プログラムのヘルプファィル「"
            error += file
            error += "」が「"
            error += HELP_DIRECTORY
            error += "」にありません．\n"
    # load defaults value.
    try:
        with open(defaults_file, mode='r', encoding='utf-8') as f:
            configuration = yaml.safe_load(f)
    except Exception as e:
        error = f'設定ファイル({defaults_file})をロードできません．'
        return error
    loadMenuValue()
    return ''

if __name__ == "__main__":
    if "" == init():
        thread = threading.Thread(target=documentServer, daemon=True) # 処理を割り当てる
        thread.start() # スレッドを起動する
        ft.run(editWindow)
    else:
        ft.run(errorWindow)
