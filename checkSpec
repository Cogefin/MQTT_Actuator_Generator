    def route_change(handler):
        global configuration
        page.views.clear()
        if page.route == "/viewTop":
            page.views.append(createViewTop())
        if page.route == "/viewArduino":
            page.views.append(createViewArduino())
        if page.route == "/viewLoadFile":
            page.views.append(createViewLoadFile())
        if page.route == "/viewSummary":
            page.views.append(createViewSummary())
        if page.route == "/viewAnalyzeResulty":
            page.views.append(createViewAnalyzeResult())
        page.update()
    page.on_route_change = route_change
    page.window.height = 600
    page.autoscroll = True
    asyncio.create_task(page.push_route("/viewTop"))

def errorWindow(page: ft.Page):
    async def finish_button_clicked(e):
        await page.window.destroy()
    global error
    page.title = "エラー"
    page.autoscroll = True
    finish_button = ft.Button(content="終了", on_click=finish_button_clicked)
    page.add(
        ft.SafeArea(
            content=ft.Column(
                height=600,
                scroll=ft.ScrollMode.ALWAYS,
                controls=[
                    ft.AppBar(title=ft.Text("重大なエラー"), bgcolor=ft.Colors.RED),
                    ft.Text(error),
                    ft.Divider(height=2, color="black"),
                    finish_button,
                ],
            )
        )
    )

def init():
    global error, arduino_info, actuator_info, HELP_DIRECTORY, HELP_FILES, CONFIG_FILE_DIR, CONFIG_FILES
    error=''
    pwd=os.getcwd()
    pwd = pwd.replace('\\', '/')
    pwd = pwd.replace(' ', '\\ ')
    pwd = pwd + "/"
    # check configuration files.
    for file in CONFIG_FILES:
        target_path = CONFIG_FILE_DIR + file
        if not (os.path.isfile(pwd+target_path)):
            error += "本プログラムの設定ファィル「"
            error += file
            error += "」が「"
            error += CONFIG_FILE_DIR
            error += "」にありません．\n"
        else:
            if file == "Arduino.yaml":
                try:
                    with open(target_path, mode='r', encoding='utf-8') as f:
                        arduino_info = yaml.safe_load(f)
                except Exception as e:
                    error += 'Arduinoの機種情報ファイル(Arduino.yaml)が読み読み込みできません．\n'
            elif file == "ActuatorDevices.yaml":
                try:
                    with open(target_path, mode='r', encoding='utf-8') as f:
                        actuator_info = yaml.safe_load(f)
                except Exception as e:
                    error += 'アクチュエータの情報ファイル(ActuatorDevices.yaml)が読み読み込みできません．\n'
    # check help files, phase 1.
    for file in HELP_FILES:
        target_path = HELP_DIRECTORY + file
        if not (os.path.isfile(pwd+target_path)):
            error += "本プログラムのヘルプファィル「"
            error += file
            error += "」が「"
            error += HELP_DIRECTORY
            error += "」にありません．\n"
    setup_pin_assignment()
    return error

if __name__ == "__main__":
    if "" == init():
        thread = threading.Thread(target=documentServer, daemon=True) # 処理を割り当てる
        thread.start() # スレッドを起動する
        ft.run(mainWindow)
    else:
        ft.run(errorWindow)
