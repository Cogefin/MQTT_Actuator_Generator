def checkPinMap():
    global pin_assignment, selected_arduino, arduino_info
    controls = []
    # 最大ピン番号の確認
    arduino_max_pin = arduino_info['Arduino'][selected_arduino['name']]['max_pin']
    if arduino_max_pin!=(PIN_MAX-1):
        for i in range(arduino_max_pin+1, PIN_MAX, 1):
            if pin_assignment['digital'][i]>0:
                controls.append(ft.Text('Arduinoの最大ピン番号を超えるピンが割り当てられています．Arduinoの最大ピン番号は{}ですが，{}が割り当てられています．'.format(arduino_max_pin, i)))
    # ピンの重複の確認
    for i in range(0, arduino_max_pin+1, 1):
        if pin_assignment['digital'][i]>1:
            controls.append(ft.Text('ピン{}が複数のデバイスに割り当てられています．'.format(i)))
    # シリアルの重複の確認
    if pin_assignment['serial']>1:
        controls.append(ft.Text('シリアルインターフェースを使えるデバイスは1つに制限されます．'))
    # get pin number
    arduino_name = selected_arduino['name']
    sck_pin = arduino_info['Arduino'][arduino_name]['spi']['SCK']
    mosi_pin = arduino_info['Arduino'][arduino_name]['spi']['MOSI']
    miso_pin = arduino_info['Arduino'][arduino_name]['spi']['MISO']
    i2c_clk_pin = arduino_info['Arduino'][arduino_name]['i2c']['SCL']
    i2c_data_pin = arduino_info['Arduino'][arduino_name]['i2c']['SDA']
    if pin_assignment['spi']:
        if (pin_assignment['digital'][sck_pin] > 1) or (pin_assignment['digital'][mosi_pin] > 1) or (pin_assignment['digital'][miso_pin] > 1):
            controls.append(ft.Text('SPIインターフェースのピンが他の用途で使われています．'))
    if pin_assignment['i2c']:
        if (pin_assignment['digital'][i2c_clk_pin] > 1) or (pin_assignment['digital'][i2c_data_pin] > 1):
