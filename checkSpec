        next_button = ft.Button(content="次", on_click=next_button_clicked)
        warning_message = ft.Text()
        finish_button = ft.Button(content="終了", on_click=finish_button_clicked)
        specFileSelectionButton = ft.Button(
            content="ファイル選択",
            icon=ft.Icons.UPLOAD_FILE,
            on_click=pick_input_file_dialog,
        )
        return ft.View(route="/viewLoadFile", controls=[
            ft.SafeArea(
                content=ft.Column(
