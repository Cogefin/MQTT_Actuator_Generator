def setup_pin_assignment():
    global pin_assignment
    for i in range(PIN_MAX):
        pin_assignment['digital'].append(0)

def clear_pin_assignment():
    global pin_assignment
    for i in range(PIN_MAX):
        pin_assignment['digital'][i]=0
    pin_assignment['spi']=False
    pin_assignment['i2c']=False
    pin_assignment['serial']=0

class Handler(http.server.SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, directory=HELP_DIRECTORY, **kwargs)

def documentServer():
    global PORT
    flag=True
    PORT=PORT_LOWER_LIMIT
    while flag:
        try:
            with socketserver.TCPServer((LOCAL_HOST_IP, PORT), Handler) as httpd:
                flag=False
                httpd.serve_forever()
        except Exception as e:
            PORT+=1

