    global configuration
    flag='use_' + actuator_name
    return configuration[actuator_name][flag]

def checkActuatorUsePwm(category, actuator_name):
    global actuator_info
    return actuator_info[category][actuator_name]['pwm']

def checkActuatorPWM():
    global configuration, actuator_info
    controls = []
    #
    # さまざまなLED
    #
    # Simple mono LED
    if checkActuatorEnabled('simple_mono_led') and checkActuatorUsePwm('led', 'grove_mono_led'):
        if not checkPwmPin(configuration['simple_mono_led']['simple_mono_led_pin']):
            controls.append(ft.Text(actuator_info['led']['grove_mono_led']['name']))
    # Simple color LED
    if checkActuatorEnabled('simple_color_led') and checkActuatorUsePwm('led', 'cathod_common_color_led'):
        if not checkPwmPin(configuration['simple_color_led']['simple_color_led_red_pin']) or checkPwmPin(configuration['simple_color_led']['simple_color_led_green_pin']) or checkPwmPin(configuration['simple_color_led']['simple_color_led_blue_pin']):
            controls.append(ft.Text(actuator_info['led']['simple_color_led']['name']))
    # simple PWM device
    if checkActuatorEnabled('pwm') and checkActuatorUsePwm('pwm', 'grove_mono_led'):
        if not checkPwmPin(configuration['pwm']['pwm_pin']):
            controls.append(ft.Text(actuator_info['pwm']['grove_mono_led']['name']))
    if len(controls)==0:
        controls.append(ft.Text('PWMに問題があるデバイスはありません．'))
    return controls

