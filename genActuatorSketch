def fileWindow(page: ft.Page):
    def icon_clicked(e):
        asyncio.create_task(page.push_route("/viewHelp"))
    def createViewError():
        global error
        def close_button_clicked(e):
            asyncio.create_task(page.push_route("/viewMain"))
        global lastView
        lastView = "/viewError"
        page.title = "スケッチ生成失敗"
        page.window_width = 800
        page.window_height = 500
        page.autoscroll = True
        pageTitleBar = ft.AppBar(
            title=ft.Text("スケッチ生成失敗"),
            bgcolor=ft.Colors.YELLOW,
            actions=[
                ft.IconButton(icon = ft.Icons.HELP_CENTER, on_click=icon_clicked),
            ]
        )
        close_button = ft.Button(content="閉じる", on_click=close_button_clicked)
        return ft.View(route="/viewError", controls=[
            ft.SafeArea(
                content=ft.Column(
                    controls=[
                        pageTitleBar,
                        close_button,
                        ft.Text(error),
                    ],
                ),
            )   
        ])
    def createViewHelp():
        def close_button_clicked(e):
            global lastView
            #asyncio.create_task(page.push_route("/viewMain"))
            asyncio.create_task(page.push_route(lastView))
        page.title = "IoTアクチュエータスケッチ生成ヘルプ"
        page.window_width = 800
        page.window_height = 500
        page.autoscroll = True
        help_contents = ft.Markdown(help['top'], selectable=True, extension_set=ft.MarkdownExtensionSet.GITHUB_WEB)
        pageTitleBar = ft.AppBar(
            title=ft.Text("スケッチ生成ヘルプ"),
            bgcolor=ft.Colors.BLUE,
            #actions=[
            #    ft.IconButton(icon = ft.Icons.HELP_CENTER, on_click=icon_clicked),
            #]
        )
        close_button = ft.Button(content="閉じる", on_click=close_button_clicked)
        return ft.View(route="/viewHelp", controls=[
            ft.SafeArea(
                content=ft.Column(
                    controls=[
                        pageTitleBar,
                        close_button,
                        help_contents,
                    ],
                ),
            )   
        ])
    def createViewMain():
        async def exec_button_clicked(e):
            if source_file_name=="":
                warning_message.value = "入力の仕様ファイルを選択してください．"
                warning_message.update()
                return
            if output_directory_path=="":
                warning_message.value = "Arduinoのスケッチを出力するフォルダを選択してください．"
                warning_message.update()
                return
            if '' != exec_command():
                asyncio.create_task(page.push_route("/viewError"))
            else:
                await page.window.destroy()
            
        async def pick_input_file_dialog(e: ft.Event[ft.Button]):
            global source_file_name
            files = await ft.FilePicker().pick_files(allow_multiple=False)
            if files:
                selected_input_file.value = files[0].path
                source_file_name = selected_input_file.value
            else:
                selected_input_file.value = "キャンセルされました."
                source_file_name = ""
            selected_input_file.update()

        async def pick_output_file_dialog(e: ft.Event[ft.Button]):
            global output_directory_path
            output_directory_path = await ft.FilePicker().get_directory_path()
            if output_directory_path == "":
                selected_output_file.value = "キャンセルされました．"
            else:
                selected_output_file.value = output_directory_path
            selected_output_file.update()

        async def applicationFinish(e: ft.Event[ft.Button]):
            await page.window.destroy()

        global lastView
        lastView="/viewMain"
        page.title = "IoTアクチュエータスケッチ生成"
        page.window_width = 400
        page.window_height = 500
        selected_input_file = ft.Text()
        selected_output_file = ft.Text()
        exec_button = ft.Button(content="スケッチ生成", on_click=exec_button_clicked)
        warning_message = ft.Text()
        finish_button = ft.Button(content="終了", on_click=applicationFinish)
        pageTitleBar = ft.AppBar(
            title=ft.Text("スケッチ生成"),
            bgcolor=ft.Colors.BLUE,
            actions=[
                ft.IconButton(icon = ft.Icons.HELP_CENTER, on_click=icon_clicked),
            ]
        )
        specFileSelectionButton = ft.Button(
            content="ファイル選択",
            icon=ft.Icons.UPLOAD_FILE,
            on_click=pick_input_file_dialog,
        )
        outputFolderSelectionButton = ft.Button(
            content="フォルダ選択",
            icon=ft.Icons.DOWNLOAD,
            on_click=pick_output_file_dialog,
        )
        return ft.View(route="/viewMain", controls=[
            ft.SafeArea(
                content=ft.Column(
                    controls=[
                        pageTitleBar,
                        ft.Text("仕様ファイル指定", theme_style=ft.TextThemeStyle.TITLE_MEDIUM),
                        specFileSelectionButton,
                        selected_input_file,
                        ft.Divider(height=2, color="black"),
                        ft.Text("スケッチ出力先指定", theme_style=ft.TextThemeStyle.TITLE_MEDIUM),
                        outputFolderSelectionButton,
                        selected_output_file,
                        ft.Divider(height=2, color="black"),
                        ft.Row(
                            [exec_button,warning_message,]
                        ),
                        finish_button,
                    ],
                ),
            )   
        ])
    def route_change(handler):
        global configuration, lastView
        page.views.clear()
        if page.route == "/viewMain":
            page.views.append(createViewMain())
        if page.route == "/viewHelp":
            page.views.append(createViewHelp())
        if page.route == "/viewError":
            page.views.append(createViewError())
        page.update()
    page.on_route_change = route_change
    asyncio.create_task(page.push_route("/viewMain"))

