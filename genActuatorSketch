def checkProgramFiles():
    global error
    pwd=os.getcwd()
    pwd = pwd.replace('\\', '/')
    pwd = pwd.replace(' ', '\\ ')
    pwd = pwd + "/"
    # check Arduino sketch
    if not (os.path.isfile(pwd+sketch_source)):
        error = 'Arduinoスケッチのテンプレートファイル('
        error += sketch_source
        error += ')が規定の場所にありません．\n'
    # check utility source files.
    utility_source_files = [RTC_source, actuator_hdr, actuator_source, additional_hdr, watchdog_hdr, watchdog_source]
    for file in (utility_source_files):
        if not (os.path.isfile(pwd+file)):
            error += 'ソースファイル\''
            error += file
            error += '\'がありません．\n'
    # check device driver source files.
    if not (os.path.isdir(pwd+driver_dir)):
        error += 'デバイスドライバ集のフォルダ('
        error += driver_dir
        error += ')が規定の場所にありません．\n'
    return error

def checkApplicationEnvironment():
    global error
    checkResult = checkProgramFiles()
    checkResult += loadHelpFile()
    return checkResult

if __name__ == "__main__":
