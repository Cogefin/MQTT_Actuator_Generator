def exec_command():
    global source_file_name, output_directory_path, sketch_name, output_file , output_dir, error, configuration
    output_dir = output_directory_path + "/" + sketch_name + "/"
    try:
        with open(source_file_name, mode='r', encoding='utf-8') as f:
            configuration = yaml.safe_load(f)
    except Exception as e:
        error = 'yamlファイルのロードに失敗しました．'
        return error
    checkResult = checkConfiguration()
    if '' != checkResult:
        error = checkResult
        return error
    copySketch()
    try:
        output_file = open(output_dir+"config.h", mode='w', encoding='utf-8')
    except Exception as e1:
        error = 'ファイル(config.h)の出力に失敗しました．'
        return error
    #
    # Character LCD
    #
    # Grove LCD RGB backlight
    if 'grove_lcd' in configuration:
        grove_lcd(configuration['grove_lcd'])
    # ACM1602NI
    if 'acm1602ni' in configuration:
        acm1602ni(configuration['acm1602ni'])
    # Liquid crystal library
    if 'liquid_crystal' in configuration:
        liquid_crystal(configuration['liquid_crystal'])
    #
    # several kinds of LED
    #
    # Simple mono-chrome LED
    if 'simple_mono_led' in configuration:
        simple_mono_led(configuration['simple_mono_led'])
    # Anode/Cathod common LED
    if 'simple_color_led' in configuration:
        simple_color_led(configuration['simple_color_led'])
    # Grove LED Bar
    if 'grove_led_bar' in configuration:
        grove_led_bar(configuration['grove_led_bar'])
    # Grove LED Circular
    if 'grove_led_circular' in configuration:
        grove_led_circular(configuration['grove_led_circular'])
    # Grove chainable (RGB) LED
    if 'grove_chainable_led' in configuration:
        grove_chainable_led(configuration['grove_chainable_led'])
    # Adafruit NeoPixel
    if 'adafuit_neopixel' in configuration:
        adafuit_neopixel(configuration['adafuit_neopixel'])
    #
    # N-segment LED
    #
    # OSL12306-16
    if 'osl12306_16' in configuration:
        osl12306_16(configuration['osl12306_16'])
    # OSL20541
    if 'osl20541' in configuration:
        osl20541(configuration['osl20541'])
    # OSL30561
    if 'osl30561' in configuration:
        osl30561(configuration['osl30561'])
    # Grove - 4-Digit Display (clock type)
    if 'grove_tm1637' in configuration:
        grove_tm1637(configuration['grove_tm1637'])
    # DFRobot DFR0090
    if 'dfr0090' in configuration:
        dfr0090(configuration['dfr0090'])
    #
    # サーボ
    #
    if 'servo' in configuration:
        servo(configuration['servo'])
    #
    # simple sound
    # スピーカー
    if 'speaker' in configuration:
        speaker(configuration['speaker'])
    # ブザー
    if 'buzzer' in configuration:
        buzzer(configuration['buzzer'])
    #
    # simple PMW device
    #
    if 'pmw' in configuration:
        pmw(configuration['pmw'])
    #
    # simple digital(ON/OFF) device (like switch)
    #
    if 'switch' in configuration:
        switch(configuration['switch'])
    #
    # IR LED remote control device
    #
    if 'ir_remote' in configuration:
        ir_remote(configuration['ir_remote'])
    #
    # MP3 player
    #
    if 'mp3_player' in configuration:
        mp3_player(configuration['mp3_player'])
    #
    # Graphic display
    #
    if 'graphic_display' in configuration:
        graphic_display(configuration['graphic_display'])
    #
    # base configurations
    #
    platform(configuration['platform'])
    common(configuration['common'])
    network(configuration['network'])
    safety(configuration['safety'])
    #
    # tail of header
    #
    config_header_tail()
    #
    # 後始末
    #
    output_file.close()
    return ''

def errorWindow(page: ft.Page):
    async def finish_button_clicked(e):
        await page.window.destroy()
    global error
    page.title = "エラー"
    page.window_width = 400
    page.window_height = 500
    page.autoscroll = True
    finish_button = ft.Button(content="閉じる", on_click=finish_button_clicked)
    page.add(
        ft.SafeArea(
            content=ft.Column(
                controls=[
                    ft.AppBar(title=ft.Text("重大なエラー"), bgcolor=ft.Colors.RED),
                    ft.Text(error),
                    ft.Divider(height=2, color="black"),
                    finish_button,
                ],
            )
        )
