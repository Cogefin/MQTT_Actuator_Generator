def copySketch():
    global output_directory_path, output_dir, sketch_name, sketch_source
    if not os.path.isdir(output_dir) :
        os.mkdir(output_dir)
    if os.path.isfile(output_dir+'config.h') :
        os.remove(output_dir+'config.h')
    shutil.copyfile(sketch_source, output_dir+sketch_name+'.ino')
    shutil.copyfile(RTC_source, output_dir+ 'RTC.cpp')
    shutil.copyfile(actuator_hdr, output_dir+ 'ActuatorHAL.h')
    shutil.copyfile(actuator_source, output_dir+ 'ActuatorHAL.cpp')
    shutil.copyfile(additional_hdr, output_dir+ 'AdditionalDef.h')
    shutil.copyfile(watchdog_hdr, output_dir+ 'watchdog.h')
    shutil.copyfile(watchdog_source, output_dir+ 'watchdog.cpp')
    shutil.copytree(driver_dir, output_dir+'src')

