def loadHelpFile():
    global help_file, help, error
    try:
        with open(help_file, mode='r', encoding='utf-8') as f:
            help = yaml.safe_load(f)
    except Exception as e:
        error += '本アプリケーションのヘルプファイルが読み込みできません．\n'
        return error
    return ''

